# Copy to v4b/v4b_config.env and edit the APEX command once.

START_GENERATION=1
END_GENERATION=10
DEVICE=cuda

N_PARENTS=512
N_OFFSPRING=10000
N_SURVIVORS=2500
BATCH_SIZE=512
ENCODE_BATCH_SIZE=256
PROPOSAL_MULTIPLIER=4.0
CROSSOVER_RATE=0.20

# Exploration-to-exploitation schedule across Generations 1-10.
LATENT_SIGMA_START=0.35
LATENT_SIGMA_END=0.15
TEMPERATURE_START=0.85
TEMPERATURE_END=0.65

BASE_SEED=20260716
CHECKPOINT=v3/checkpoints/amp_jepa_hybrid_v3_qc_core.pt
RESULTS_ROOT=v4b/results

# Required contract:
# - {input} is replaced with the current generation candidate CSV.
# - {output} is replaced with the required score CSV path.
# - {generation} is replaced with the current generation number.
# - the scorer must preserve candidate_id or sequence and return one row per input.
#
# Replace this example with the exact APEX scoring command already used in your environment.
APEX_SCORER_CMD='python /absolute/path/to/your_apex_scorer.py --input {input} --output {output}'
