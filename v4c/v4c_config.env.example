# Copy to v4c/v4c_config.env and edit only if your local APEX path differs.

START_GENERATION=1
END_GENERATION=10
DEVICE=cuda

# Frozen V4B evolutionary bottlenecks; only offspring scale increases ten-fold.
N_PARENTS=512
N_OFFSPRING=100000
N_SURVIVORS=2500

BATCH_SIZE=512
ENCODE_BATCH_SIZE=256
PROPOSAL_MULTIPLIER=4.0
CROSSOVER_RATE=0.20

# Exploration-to-exploitation schedule retained from V4B.
LATENT_SIGMA_START=0.35
LATENT_SIGMA_END=0.15
TEMPERATURE_START=0.85
TEMPERATURE_END=0.65

# Cool-down after a completed generation, except after the final generation.
REST_BETWEEN_GENERATIONS_SECONDS=60

BASE_SEED=20260716
CHECKPOINT=v3/checkpoints/amp_jepa_hybrid_v3_qc_core.pt
RESULTS_ROOT=v4c/results

# Required contract:
# - {input} is replaced with the current generation candidate CSV.
# - {output} is replaced with the required APEX score CSV.
# - {generation} is replaced with the current generation number.
# - the scorer must preserve candidate_id or sequence and return one row per input.
#
# This uses the same proven chunked APEX adapter as V4B.
APEX_SCORER_CMD='python v4b/apex_score_chunked_wrapper.py --input {input} --output {output} --apex-root /home/julojays/apex --batch-size 64 --min-batch-size 8 --device cuda'
